# =============================================================================
# KR Global Solutions LTD — Variables d'environnement
# Copier ce fichier en .env.local pour le développement local.
# Sur Vercel : Settings → Environment Variables
# =============================================================================

# --- STRIPE ---
# Clé secrète Stripe (dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=sk_live_...

# Secret de signature du webhook Stripe
# Local : stripe listen --forward-to localhost:3000/api/stripe/webhook → copier le signing secret
# Prod  : dashboard.stripe.com → Developers → Webhooks → ton endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# --- RESEND ---
# Clé API Resend (resend.com → API Keys)
RESEND_API_KEY=re_...

# Adresse expéditeur — doit utiliser ton domaine vérifié dans Resend
RESEND_FROM_EMAIL="KR Global Solutions LTD <orders@krglobalsolutionsltd.com>" # FIXED: quoted to avoid parseur .env truncating on spaces/chevrons

# --- EMAIL NOTIFICATIONS ---
# Email interne qui reçoit une copie de chaque nouvelle commande
INTERNAL_NOTIFICATION_EMAIL=orders@krglobalsolutionsltd.com

# Email affiché dans les emails clients pour le support
CUSTOMER_SUPPORT_EMAIL=support@krglobalsolutionsltd.com

# Lien WhatsApp Business affiché dans les emails clients
CUSTOMER_SUPPORT_WHATSAPP=https://wa.me/33743561304?text=Bonjour%2C%20j%27ai%20une%20question%20sur%20ma%20commande.

# Lien Calendly affiché dans les emails clients
CUSTOMER_SUPPORT_CALENDLY=https://calendly.com/krglobalsolutionsltd/30-minute-meeting-clone

# --- SUPABASE ---
# URL du projet Supabase (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Clé service_role — NE JAMAIS exposer côté client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# --- APPLICATION ---
# URL publique du site (sans slash final)
# Local : http://localhost:3000
# Prod  : https://ton-domaine.com
NEXT_PUBLIC_APP_URL=https://ton-domaine.com

# --- ADMIN ---
# Secret partagé pour protéger les endpoints API admin (/api/admin/*)
# Générer : openssl rand -hex 32
ADMIN_SECRET=change_me_avec_une_valeur_longue_et_aleatoire

# Identifiants Basic Auth pour la page /admin (protégée par middleware)
ADMIN_USER=admin
ADMIN_PASSWORD=change_me_avec_un_mot_de_passe_fort

# --- SENTRY (optionnel) ---
# DSN du projet Sentry (sentry.io → Settings → Projects → Client Keys)
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Org et projet Sentry — nécessaires pour l'upload des source maps au build
# SENTRY_ORG=ton-organisation
# SENTRY_PROJECT=ton-projet

# --- ANALYTICS (optionnel) ---
# Google Analytics 4 Measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
